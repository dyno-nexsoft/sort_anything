{
  "name": "sort-anything",
  "displayName": "Sort Anything",
  "description": "Sort keys in JSON/YAML/ENV files and generate AI-powered commit messages",
  "version": "0.0.9",
  "publisher": "dyno-nexsoft",
  "author": "Dyno Nexsoft",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dyno-nexsoft/sort_anything.git"
  },
  "keywords": [
    "sort",
    "json",
    "yaml",
    "env",
    "properties",
    "format"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:json",
    "onLanguage:jsonc",
    "onLanguage:yaml",
    "onLanguage:properties",
    "onLanguage:env",
    "onLanguage:dotenv",
    "onLanguage:ignore",
    "onLanguage:plaintext",
    "onCommand:sortAnything.generateDartBarrel",
    "onCommand:sortAnything.generateCommitMessage"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sortAnything.sortDocument",
        "title": "Sort Anything: Sort Document"
      },
      {
        "command": "sortAnything.sortSelection",
        "title": "Sort Anything: Sort Selection"
      },
      {
        "command": "sortAnything.generateDartBarrel",
        "title": "Generate Dart Barrel File",
        "icon": "$(file-code)"
      },
      {
        "command": "sortAnything.generateCommitMessage",
        "title": "Generate Commit Message with AI",
        "icon": "$(sparkle)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == json || resourceLangId == jsonc || resourceLangId == yaml || resourceLangId == properties || resourceLangId == env || resourceLangId == dotenv || resourceLangId == ignore || resourceLangId == plaintext",
          "command": "sortAnything.sortDocument",
          "group": "1_modification"
        },
        {
          "when": "editorHasSelection && (resourceLangId == json || resourceLangId == jsonc || resourceLangId == yaml || resourceLangId == properties || resourceLangId == env || resourceLangId == dotenv || resourceLangId == ignore || resourceLangId == plaintext)",
          "command": "sortAnything.sortSelection",
          "group": "1_modification"
        }
      ],
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder",
          "command": "sortAnything.generateDartBarrel",
          "group": "2_workspace@1"
        }
      ],
      "scm/inputBox": [
        {
          "command": "sortAnything.generateCommitMessage",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Sort Anything",
      "properties": {
        "sortAnything.aiProvider": {
          "type": "string",
          "enum": ["gemini", "ollama"],
          "default": "gemini",
          "description": "AI provider để gen commit message."
        },
        "sortAnything.geminiApiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Gemini API Key. Lấy tại [Google AI Studio](https://aistudio.google.com/apikey)."
        },
        "sortAnything.geminiModel": {
          "type": "string",
          "default": "gemini-2.0-flash",
          "description": "Model Gemini (e.g. gemini-2.0-flash, gemini-1.5-pro)."
        },
        "sortAnything.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Endpoint của Ollama server."
        },
        "sortAnything.ollamaModel": {
          "type": "string",
          "default": "llama3",
          "description": "Model Ollama (e.g. llama3, mistral, codellama)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package-to-desktop": "vsce package -o \"%USERPROFILE%\\Desktop\\sort-anything.vsix\""
  },
  "dependencies": {
    "comment-json": "^4.2.3",
    "yaml": "^2.3.1"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.1.3"
  }
}
